# Copie para .env.production na VPS:
#   cp .env.production.example .env.production
# Edite todas as chaves marcadas com CHANGE-ME antes de subir.

# --- Banco principal (app) ---
POSTGRES_DB=barbersaas
POSTGRES_USER=barbersaas
POSTGRES_PASSWORD=CHANGE-ME-postgres-password

# --- App web ---
WEB_PORT=3000
JWT_SECRET=CHANGE-ME-jwt-secret-longa-aleatoria
CRON_SECRET=CHANGE-ME-cron-secret
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# Primeiro deploy: cria planos + Super Admin (desative depois)
SEED_ON_START=true
SEED_ADMIN_EMAIL=guhgames46@gmail.com
SEED_ADMIN_PASSWORD=CHANGE-ME-admin-password

# --- Pagamentos Asaas ---
ASAAS_API_KEY=
ASAAS_SANDBOX=false
ASAAS_WEBHOOK_TOKEN=CHANGE-ME-webhook-token

# --- E-mail (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=BarberSaaS <noreply@seudominio.com.br>

# --- WhatsApp (Evolution API) ---
# URL interna (entre containers Docker) — não altere se usar este compose
EVOLUTION_API_URL=http://evolution-api:8080
# Mesma chave em EVOLUTION_API_KEY e AUTHENTICATION da Evolution
EVOLUTION_API_KEY=CHANGE-ME-evolution-api-key
# URL pública da Evolution (proxy reverso / subdomínio) — usada pelo manager/QR
EVOLUTION_PUBLIC_URL=https://evolution.seudominio.com.br
EVOLUTION_PORT=8080

# Banco isolado da Evolution (não é o mesmo do app)
EVOLUTION_POSTGRES_DB=evolution_api
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=CHANGE-ME-evolution-db-password
